# Base URL of the admin (NestJS) backend API.
# Copy to .env. The dev backend listens on http://localhost:3000.
VITE_API_URL=http://localhost:3000

# Public base URL for resolving image storage keys (order item thumbnails build
# `${VITE_STORAGE_URL}/<storageKey>`). Defaults to the dev R2 bucket when unset;
# point it at your environment's public storage/CDN base in production.
# VITE_STORAGE_URL=https://pub-caf9265870784196a65cfec387edb41a.r2.dev
